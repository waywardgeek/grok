// spawn.gk — spawn statement (goroutine launching)

grok spawn_demo {
  func main() {
    // Basic spawn
    spawn {
      let x = 42
      println(f"hello from goroutine: {x}")
    }

    // Spawn with loop
    spawn {
      for i in [1, 2, 3] {
        println(f"item: {i}")
      }
    }

    // Nested spawn
    spawn {
      spawn {
        println("nested goroutine")
      }
    }

    println("spawned goroutines")
  }
}
