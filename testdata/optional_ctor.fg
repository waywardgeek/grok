// optional_ctor.fg — test optional fields in class constructors auto-wrap

forge optional_ctor {

class User(name: string, email: string?) {
    func get_name(self) -> string {
        return self.name
    }
}

fn main() {
    let u1 = User("Alice", "alice@example.com")
    let u2 = User("Bob", null)
    println(u1.get_name())
    if !isnull(u2.email) {
        println("has email")
    }
}

}
