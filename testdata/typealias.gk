// testdata/typealias.gk — type alias tests

grok typealias {
    type StringList = [string]
    type IntOrString = i32 | string
    type MaybeInt = i32?

    func test_aliases() {
        let names: StringList = ["alice", "bob"]
        println(names.len())

        let val: IntOrString = 42
        let maybe: MaybeInt = 10
    }
}
