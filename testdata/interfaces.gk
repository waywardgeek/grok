grok Interfaces {
  interface Graph<G, N, E> {
    func G.nodes(self) -> [N]
    func G.edges(self) -> [E]
    func N.out_edges(self) -> [E]
    func E.src_node(self) -> N
    func E.tgt_node(self) -> N
    func distance(a: N, b: N) -> i32
  }

  class MyGraph(nodes_list: [MyNode], edges_list: [MyEdge]) {
    pub func components(self) -> [MyNode] {
      return self.nodes_list
    }
    pub func wires(self) -> [MyEdge] {
      return self.edges_list
    }
  }

  class MyNode(name: string, out: [MyEdge]) {
    pub func outWires(self) -> [MyEdge] {
      return self.out
    }
  }

  class MyEdge(src: MyNode, tgt: MyNode) {
    pub func driver(self) -> MyNode {
      return self.src
    }
    pub func receiver(self) -> MyNode {
      return self.tgt
    }
  }

  impl Graph<MyGraph, MyNode, MyEdge> {
    G.nodes = MyGraph.components
    G.edges = MyGraph.wires
    N.out_edges = MyNode.outWires
    E.src_node = MyEdge.driver
    E.tgt_node = MyEdge.receiver
    E.distance(a: MyNode, b: MyNode) -> i32 {
      return 1
    }
  }

  func main() {
    let n1 = MyNode("A", [])
    let n2 = MyNode("B", [])
    let e1 = MyEdge(n1, n2)
    let g = MyGraph([n1, n2], [e1])
    let nodes = g.components()
    println(n1.name)
    println(n2.name)
    println(e1.driver().name)
    println("PASS")
  }
}
